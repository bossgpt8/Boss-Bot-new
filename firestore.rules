// Firestore Security Rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow the user to read and write their own data
    // This is a basic rule, you might want to restrict it further based on your app's needs
    match /{document=**} {
      allow read, write: if true; // WARNING: This allows anyone to read/write. 
      // For production, use something like:
      // allow read, write: if request.auth != null;
    }
  }
}
